rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // medtrack-verifications: authenticated users can upload/read their own files
    match /medtrack-verifications/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // verifications: video clips from verification sessions
    match /verifications/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // videos/{deviceId}/{filename}: medication verification recordings.
    // Auto-deleted after 24h by Cloud Function (functions/src/index.ts).
    // Any authenticated user (patient OR relative) can read; only authenticated
    // users can write a new mp4 under 50 MB.
    match /videos/{deviceId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType == 'video/mp4';
      allow delete: if request.auth != null;
    }

    // Authenticated users can read/write (max 50MB)
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
    }
  }
}